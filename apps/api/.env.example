# ── Required ──────────────────────────────────────────────────────────────────
# Secret master key for owner login (min 32 chars recommended)
OWNER_MASTER_KEY=change-me-at-least-32-chars-long

# Secret used to sign JWTs (min 32 chars recommended)
JWT_SECRET=change-me-jwt-secret-at-least-32-chars

# ── Optional: MongoDB (leave unset to use filesystem storage) ─────────────────
# MONGO_URI=mongodb://localhost:27017/cms-ai

# ── Optional: AI providers (at least one required for AI chat feature) ────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...

# ── Optional: Deployment adapters ─────────────────────────────────────────────
# DEPLOY_ADAPTER=vercel   # or: render
# VERCEL_TOKEN=...
# VERCEL_SCOPE=mateohaines02-5710s-projects   # your Vercel team/personal scope slug
# RENDER_API_KEY=...

# ── Optional: Owner 2FA ────────────────────────────────────────────────────────
# OWNER_2FA_SECRET=BASE32ENCODEDTOTPSECRET

# ── Optional: Slot verification ───────────────────────────────────────────────
SLOT_VERIFY_INTERVAL_MINUTES=5

# ── Optional: Alert webhook (receives JSON POST on undetectable slot) ─────────
# ALERT_WEBHOOK_URL=https://hooks.example.com/cms-alerts

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
EDITOR_ORIGIN=http://localhost:3001
